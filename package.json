    "react-dom": "^18.3.1",
    "three": "^0.184.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.184.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "jscpd": "^5.0.6",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.7"
  }
