{
  "name": "hookstack",
  "private": true,
  "version": "0.1.0",
  "description": "Catalogue de hooks agentiques pour Claude Code",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=--no-deprecation next dev",
    "build": "next build",
