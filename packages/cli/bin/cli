#!/usr/bin/env node
import { readFileSync, writeFileSync, mkdirSync, existsSync, readdirSync, realpathSync, mkdtempSync, rmSync, copyFileSync } from 'fs'
import { join as pathJoin } from 'path'
import { homedir, tmpdir } from 'os'
import { join, dirname } from 'path'
import { fileURLToPath } from 'url'
import { execFileSync } from 'node:child_process'
import pc from 'picocolors'
import * as p from '@clack/prompts'
import {
  parseArgs,
  resolveScopeRoot,
  mergeHooks,
  assertSafeTarget,
  collectIncomingHooks,
  resolveScriptPath,
  buildSecurityRows,
  buildPostInstallHints,
  doInstallTests,
  doUpdateTests,
  findInstalledSlugs,
  detectScriptChanges,
  isGlobalScope,
  buildContributionBranch,
  buildContributionPr,
} from './core.mjs'

const API_BASE = process.env.HOOKSTACK_API_BASE || 'https://hookstack.vercel.app'
const REPO_URL = 'github.com/steve-magne/hookstack'

// "Requires X" hints block the hook from working until installed; "Optional" ones just unlock extra behavior.
const formatHint = h => h.hint.startsWith('Optional')
  ? pc.dim(`○  ${h.slug}: ${h.hint}`)
  : pc.yellow(`⚠  ${h.slug}: ${h.hint}`)
const __dirname = dirname(fileURLToPath(import.meta.url))
const VERSION = JSON.parse(readFileSync(join(__dirname, '../package.json'), 'utf8')).version

async function fetchHooks(slugs) {
  const url = slugs.length === 0
    ? `${API_BASE}/api/hooks`
    : `${API_BASE}/api/hooks?slugs=${slugs.map(encodeURIComponent).join(',')}`
  const res = await fetch(url)
  if (!res.ok) {
    const body = await res.text().catch(() => '')
    throw new Error(`API error ${res.status}: ${body}`)
  }
  return res.json()
}

// ── ASCII banner ──────────────────────────────────────────────────────────────

const BANNER = pc.cyan([
  '██╗  ██╗ ██████╗  ██████╗ ██╗  ██╗███████╗████████╗ █████╗  ██████╗██╗  ██╗',
  '██║  ██║██╔═══██╗██╔═══██╗██║ ██╔╝██╔════╝╚══██╔══╝██╔══██╗██╔════╝██║ ██╔╝',
  '███████║██║   ██║██║   ██║█████╔╝ ███████╗   ██║   ███████║██║     █████╔╝ ',
  '██╔══██║██║   ██║██║   ██║██╔═██╗ ╚════██║   ██║   ██╔══██║██║     ██╔═██╗ ',
  '██║  ██║╚██████╔╝╚██████╔╝██║  ██╗███████║   ██║   ██║  ██║╚██████╗██║  ██╗',
  '╚═╝  ╚═╝ ╚═════╝  ╚═════╝ ╚═╝  ╚═╝╚══════╝   ╚═╝   ╚═╝  ╚═╝ ╚═════╝╚═╝  ╚═╝',
].join('\n'))

// ── panel content builders ────────────────────────────────────────────────────

export function summaryPanel(rows) {
  const lines = []
  for (const r of rows) {
    lines.push(pc.cyan(r.path ?? `${r.name} (settings only)`))
    const meta = [
      r.category,
      r.events.join(', ') + (r.blocking ? pc.yellow(' · ⚡ can block') : ''),
      r.matcher ? `matcher: ${r.matcher}` : null,
    ].filter(Boolean).join(pc.dim(' · '))
    lines.push(pc.dim('  ' + meta))
    if (r.source) lines.push(pc.dim(`  source: ${r.source}`))
    lines.push('')
  }
  return lines.join('\n').trimEnd()
}

function truncPad(value, width) {
  const s = String(value ?? '')
  return (s.length > width ? s.slice(0, width - 1) + '…' : s).padEnd(width)
}

function capCell(on, width) {
  const text = (on ? 'yes' : 'no').padEnd(width)
  return on ? pc.yellow(text) : pc.dim(text)
}

const VERDICT_COLOR = { high: pc.red, medium: pc.yellow, low: pc.cyan, safe: pc.green, unknown: pc.dim }

export function securityPanel(rows) {
  const W = { name: 24, benefit: 34, cap: 7, snyk: 9, codeql: 8 }
  const header = pc.dim(
    ''.padEnd(W.name) +
    ''.padEnd(W.benefit) +
    'Shell'.padEnd(W.cap) +
    'Net'.padEnd(W.cap) +
    'Writes'.padEnd(W.cap) +
    'Snyk'.padEnd(W.snyk) +
    'CodeQL',
  )
  const body = rows.flatMap(r => {
    const benefitText = r.benefit ? truncPad(r.benefit, W.benefit) : ''.padEnd(W.benefit)
    const row = truncPad(r.name, W.name) +
      pc.dim(benefitText) +
      capCell(r.shell, W.cap) +
      capCell(r.network, W.cap) +
      capCell(r.fsWrite, W.cap) +
      (VERDICT_COLOR[r.snyk.level] ?? pc.dim)(truncPad(r.snyk.label, W.snyk)) +
      (VERDICT_COLOR[r.codeql.level] ?? pc.dim)(r.codeql.label)
    return [row]
  })
  const footer = [
    '',
    pc.dim('Shell = runs commands · Net = network access · Writes = filesystem writes'),
    pc.dim(`Details: ${API_BASE}/hook/<slug>`),
  ].join('\n')
  return [header, '', ...body, footer].join('\n')
}

// ── install ───────────────────────────────────────────────────────────────────

function doInstall(hooks, dirs, scope, log) {
  mkdirSync(dirs.claudeDir, { recursive: true })
  mkdirSync(dirs.hooksDir, { recursive: true })

  const configName = dirs.format === 'codex' ? 'hooks.json' : 'settings.json'
  let settings = {}
  if (existsSync(dirs.settingsPath)) {
    try {
      settings = JSON.parse(readFileSync(dirs.settingsPath, 'utf8'))
    } catch {
      log.warn(`Could not parse existing ${configName} — starting fresh`)
    }
  }

  const incoming = collectIncomingHooks(hooks, { scope, globalRoot: dirs.root })
  if (dirs.format === 'codex') {
    // Codex hooks.json holds events at the top level (no "hooks" wrapper).
    settings = mergeHooks(settings, incoming)
  } else {
    settings.hooks = mergeHooks(settings.hooks ?? {}, incoming)
  }
  writeFileSync(dirs.settingsPath, JSON.stringify(settings, null, 2) + '\n')

  let scriptCount = 0
  for (const hook of hooks) {
    if (!hook.script_path || !hook.code_snippet) continue
    const target = resolveScriptPath(hook.script_path, scope)
    assertSafeTarget(dirs.root, target)
    const dest = join(dirs.root, target)
    mkdirSync(join(dest, '..'), { recursive: true })
    writeFileSync(dest, hook.code_snippet, 'utf8')
    scriptCount++
  }

  return { hookCount: hooks.length, scriptCount }
}

// ── flows ─────────────────────────────────────────────────────────────────────

const plural = (n, word) => `${n} ${word}${n === 1 ? '' : 's'}`

// Human-readable destination shown in the confirm prompt and result panel.
const SCOPE_LABELS = {
  project: './.claude',
  global: '~/.claude',
  copilot: './.claude (Copilot mode)',
  'codex-project': './.codex/hooks.json (Codex)',
  'codex-profile': '~/.codex/hooks.json (Codex)',
}

function onCancel() {
  p.cancel('Installation cancelled.')
  process.exit(0)
}

async function interactiveInstall(slugs, args) {
  console.log('\n' + BANNER + '\n')
  p.intro(pc.bold('hooks') + pc.dim(`  Agentic hook installer · Claude Code · Codex · Copilot  v${VERSION}`))

  // Fetch
  const spin = p.spinner()
  spin.start(slugs.length === 0 ? 'Fetching default HookStack…' : `Fetching ${plural(slugs.length, 'hook')}…`)
  let data
  try {
    data = await fetchHooks(slugs)
  } catch (e) {
    spin.stop(pc.red(`Fetch failed: ${e.message}`), 1)
    process.exit(1)
  }
  const { hooks } = data
  const notFound = slugs.filter(slug => !hooks.find(h => h.slug === slug))
  spin.stop(`Selected ${pc.bold(String(hooks.length))} hook${hooks.length === 1 ? '' : 's'}`)
  if (notFound.length) p.log.warn(`Unknown slugs skipped: ${notFound.join(', ')}`)
  if (hooks.length === 0) { p.cancel('No hooks to install.'); process.exit(1) }

  // Scope
  let scope = args.scope
  const scopeResult = await p.select({
    message: 'Where to install?',
    options: [
      {
        value: 'project',
        label: 'Claude Code - This project',
        hint: '<repo>/.claude',
      },
      {
        value: 'global',
        label: 'Claude Code - Profile',
        hint: '~/.claude/',
      },
      {
        value: 'codex-project',
        label: 'Codex - This project',
        hint: '<repo>/.codex/',
      },
      {
        value: 'codex-profile',
        label: 'Codex - Profile',
        hint: '~/.codex/',
      },
      {
        value: 'copilot',
        label: 'GitHub Copilot - This project',
        hint: '<repo>/.claude/ Copilot compatible',
      },
    ],
    initialValue: scope,
  })
  if (p.isCancel(scopeResult)) return onCancel()
  scope = scopeResult

  const dirs = resolveScopeRoot(scope, { cwd: process.cwd(), home: homedir() })
  const secRows = buildSecurityRows(hooks)

  // Panel
  p.note(securityPanel(secRows), 'Installation Summary')

  // Confirm
  const scopeLabel = SCOPE_LABELS[scope] ?? './.claude'
  const confirmed = await p.confirm({
    message: `Install ${plural(hooks.length, 'hook')} into ${pc.cyan(scopeLabel)}?`,
  })
  if (p.isCancel(confirmed) || !confirmed) return onCancel()

  // Install
  const spin2 = p.spinner()
  spin2.start('Installing…')
  let result
  try {
    result = doInstall(hooks, dirs, scope, { warn: m => p.log.warn(m) })
  } catch (e) {
    spin2.stop(pc.red(`Install failed: ${e.message}`), 1)
    process.exit(1)
  }
  spin2.stop(`Installed ${pc.bold(String(result.hookCount))} hook${result.hookCount === 1 ? '' : 's'}`)

  // Unit tests prompt (project/copilot scope only)
  let testResult = null
  const hooksWithTests = hooks.filter(h => h.test_snippet)
  if (!isGlobalScope(scope) && hooksWithTests.length > 0) {
    const wantTests = await p.confirm({
      message: `Install unit tests for ${plural(hooksWithTests.length, 'hook')} into ${pc.cyan('tests/hooks/')}? ${pc.dim('(vitest — helps SonarQube gating)')}`,
      initialValue: true,
    })
    if (!p.isCancel(wantTests) && wantTests) {
      try {
        testResult = doInstallTests(hooks, process.cwd(), { mkdirSync, writeFileSync, join: pathJoin })
      } catch (e) {
        p.log.warn(`Could not write tests: ${e.message}`)
      }
    }
  }

  // Result panel
  const hints = buildPostInstallHints(hooks)
  const resultLines = [
    pc.green(`✓ ${dirs.settingsPath}`),
    result.scriptCount > 0
      ? pc.green(`✓ ${result.scriptCount} script${result.scriptCount === 1 ? '' : 's'} written to ${dirs.hooksDir}`)
      : null,
    testResult?.testCount > 0
      ? pc.green(`✓ ${testResult.testCount} test file${testResult.testCount === 1 ? '' : 's'} written to tests/hooks/`)
      : null,
    hints.length > 0 ? '' : null,
    ...hints.map(formatHint),
    '',
    `Browse more hooks  ${pc.cyan(`${API_BASE}/#catalogue`)}`,
    `⭐  Star us         ${pc.cyan(REPO_URL)}`,
  ].filter(v => v !== null).join('\n')

  p.note(resultLines, 'Resume installation')
  p.outro(pc.green('Done!') + pc.dim("  You've just HookStacked your agent workflow."))
}

async function directInstall(slugs, args) {
  const isDefault = slugs.length === 0
  console.log(isDefault ? '\nInstalling default HookStack…' : `\nFetching ${plural(slugs.length, 'hook')}…`)
  let data
  try {
    data = await fetchHooks(slugs)
  } catch (e) {
    console.error(`\n✗ Failed: ${e.message}`)
    process.exit(1)
  }
  const { hooks } = data
  const notFound = slugs.filter(slug => !hooks.find(h => h.slug === slug))
  if (notFound.length) console.warn(`  ! Unknown slugs (skipped): ${notFound.join(', ')}`)
  if (hooks.length === 0) {
    console.error('\n✗ No hooks to install.')
    process.exit(1)
  }
  const dirs = resolveScopeRoot(args.scope, { cwd: process.cwd(), home: homedir() })
  const log = { warn: m => console.warn(`  ! ${m}`) }
  const result = doInstall(hooks, dirs, args.scope, log)
  console.log(`  ✓ ${dirs.settingsPath}`)
  if (args.withTests && !isGlobalScope(args.scope)) {
    try {
      const testResult = doInstallTests(hooks, process.cwd(), { mkdirSync, writeFileSync, join: pathJoin })
      if (testResult.testCount > 0)
        console.log(`  ✓ ${testResult.testCount} test file${testResult.testCount === 1 ? '' : 's'} written to tests/hooks/`)
    } catch (e) {
      console.warn(`  ! Could not write tests: ${e.message}`)
    }
  }
  const hints = buildPostInstallHints(hooks)
  if (hints.length > 0) {
    for (const h of hints) console.warn(`  ${formatHint(h)}`)
  }
  const agent = dirs.format === 'codex' ? 'Codex' : 'Claude Code'
  console.log(`\n✅ ${plural(result.hookCount, 'hook')} installed · star us → ${REPO_URL}`)
  console.log(`   Restart ${agent} to activate.\n`)
}

// ── update ───────────────────────────────────────────────────────────────────
// Re-fetches every already-installed hook (recovered via its @hookstack
// fingerprint) from the live registry and refreshes the local .mjs in place.
// settings.json merge is idempotent, so it's only ever touched if a hook's
// config fragment actually changed since install.

function findUpdateTargets(dirs) {
  const slugs = findInstalledSlugs(dirs.hooksDir, { readdirSync, readFileSync })
  if (slugs.length === 0) return null
  return slugs
}

async function interactiveUpdate(args) {
  console.log('\n' + BANNER + '\n')
  p.intro(pc.bold('hooks') + pc.dim(`  Update installed hooks · v${VERSION}`))

  const dirs = resolveScopeRoot(args.scope, { cwd: process.cwd(), home: homedir() })
  const slugs = findUpdateTargets(dirs)
  if (!slugs) {
    p.cancel(`No HookStack hooks found in ${dirs.hooksDir} — run install first.`)
    process.exit(1)
  }

  const spin = p.spinner()
  spin.start(`Checking ${plural(slugs.length, 'hook')} for updates…`)
  let data
  try {
    data = await fetchHooks(slugs)
  } catch (e) {
    spin.stop(pc.red(`Fetch failed: ${e.message}`), 1)
    process.exit(1)
  }
  const { hooks } = data
  const { changed, unchanged } = detectScriptChanges(hooks, args.scope, dirs.root, { readFileSync })
  spin.stop(changed.length > 0 ? `${plural(changed.length, 'hook')} can be updated` : 'Everything is already up to date')

  if (changed.length === 0) {
    p.outro(pc.green('✓ Already up to date.'))
    return
  }

  p.note(changed.map(slug => pc.cyan(`  ${slug}`)).join('\n'), 'Hooks to update')

  const scopeLabel = SCOPE_LABELS[args.scope] ?? './.claude'
  const confirmed = await p.confirm({
    message: `Update ${plural(changed.length, 'hook')} in ${pc.cyan(scopeLabel)}?`,
  })
  if (p.isCancel(confirmed) || !confirmed) return onCancel()

  const spin2 = p.spinner()
  spin2.start('Updating…')
  let result
  try {
    result = doInstall(hooks, dirs, args.scope, { warn: m => p.log.warn(m) })
  } catch (e) {
    spin2.stop(pc.red(`Update failed: ${e.message}`), 1)
    process.exit(1)
  }
  const testResult = doUpdateTests(hooks, process.cwd(), { existsSync, writeFileSync, join: pathJoin })
  spin2.stop(`Updated ${pc.bold(String(changed.length))} hook${changed.length === 1 ? '' : 's'}`)

  const resultLines = [
    pc.green(`✓ ${result.scriptCount} script${result.scriptCount === 1 ? '' : 's'} refreshed in ${dirs.hooksDir}`),
    unchanged.length > 0 ? pc.dim(`  ${plural(unchanged.length, 'hook')} already up to date`) : null,
    testResult.testCount > 0 ? pc.green(`✓ ${testResult.testCount} test file${testResult.testCount === 1 ? '' : 's'} refreshed`) : null,
  ].filter(Boolean).join('\n')

  p.note(resultLines, 'Update summary')
  p.outro(pc.green('Done!') + pc.dim('  Restart your agent to pick up the changes.'))
}

async function directUpdate(args) {
  const dirs = resolveScopeRoot(args.scope, { cwd: process.cwd(), home: homedir() })
  const slugs = findUpdateTargets(dirs)
  if (!slugs) {
    console.error(`\n✗ No HookStack hooks found in ${dirs.hooksDir} — run install first.`)
    process.exit(1)
  }

  console.log(`\nChecking ${plural(slugs.length, 'hook')} for updates…`)
  let data
  try {
    data = await fetchHooks(slugs)
  } catch (e) {
    console.error(`\n✗ Failed: ${e.message}`)
    process.exit(1)
  }
  const { hooks } = data
  const { changed, unchanged } = detectScriptChanges(hooks, args.scope, dirs.root, { readFileSync })
  if (changed.length === 0) {
    console.log('✓ Already up to date.\n')
    return
  }

  const result = doInstall(hooks, dirs, args.scope, { warn: m => console.warn(`  ! ${m}`) })
  const testResult = doUpdateTests(hooks, process.cwd(), { existsSync, writeFileSync, join: pathJoin })
  console.log(`  ✓ ${result.scriptCount} script${result.scriptCount === 1 ? '' : 's'} refreshed in ${dirs.hooksDir}`)
  if (unchanged.length > 0) console.log(`  · ${plural(unchanged.length, 'hook')} already up to date`)
  if (testResult.testCount > 0) console.log(`  ✓ ${testResult.testCount} test file${testResult.testCount === 1 ? '' : 's'} refreshed`)
  console.log(`\n✅ ${plural(changed.length, 'hook')} updated · restart your agent to pick up the changes.\n`)
}

// ── contribute ───────────────────────────────────────────────────────────────
// Forks steve-magne/hookstack, pushes the user's locally edited hooks to a
// branch, and opens a PR — so anyone who tweaked a hook in their own project
// can hand the improvement back to the catalogue without leaving the CLI.

const UPSTREAM_REPO = 'steve-magne/hookstack'

function run(cmd, args, opts = {}) {
  return execFileSync(cmd, args, { encoding: 'utf8', stdio: ['ignore', 'pipe', 'pipe'], ...opts })
}

function findContributionCandidates(dirs, slugFilter) {
  const installed = findInstalledSlugs(dirs.hooksDir, { readdirSync, readFileSync })
  return slugFilter && slugFilter.length > 0
    ? installed.filter(s => slugFilter.includes(s))
    : installed
}

async function loadChangedHooks(slugs, scope, root) {
  const { hooks } = await fetchHooks(slugs)
  const { changed } = detectScriptChanges(hooks, scope, root, { readFileSync })
  return hooks.filter(h => changed.includes(h.slug))
}

// Forks the catalogue, clones it to a scratch dir, copies the modified .mjs
// files in, and opens a PR. Returns the PR url, or null if the fork already
// has byte-identical content (nothing to push).
function pushContribution(slugs, dirs, log) {
  try { run('gh', ['--version']) } catch {
    throw new Error('GitHub CLI (gh) is required — install: https://cli.github.com')
  }
  try { run('gh', ['auth', 'status']) } catch {
    throw new Error('Not authenticated with GitHub — run `gh auth login` first.')
  }

  const username = run('gh', ['api', 'user', '--jq', '.login']).trim()
  const workDir = mkdtempSync(join(tmpdir(), 'hookstack-contrib-'))

  try {
    log.step(`Forking ${UPSTREAM_REPO} for ${username}…`)
    run('gh', ['repo', 'fork', UPSTREAM_REPO], { cwd: workDir })

    log.step('Cloning your fork…')
    run('gh', ['repo', 'clone', `${username}/hookstack`, workDir])

    const branch = buildContributionBranch(slugs)
    run('git', ['checkout', '-b', branch], { cwd: workDir })

    for (const slug of slugs) {
      const dest = join(workDir, '.claude', 'hooks', `${slug}.mjs`)
      mkdirSync(join(dest, '..'), { recursive: true })
      copyFileSync(join(dirs.hooksDir, `${slug}.mjs`), dest)
    }

    run('git', ['add', '.claude/hooks'], { cwd: workDir })
    let hasChanges = true
    try {
      run('git', ['diff', '--cached', '--quiet'], { cwd: workDir })
      hasChanges = false
    } catch {
      hasChanges = true
    }
    if (!hasChanges) return null

    const { title, body } = buildContributionPr(slugs)
    run('git', ['commit', '-m', title], { cwd: workDir })

    log.step('Pushing branch…')
    run('git', ['push', '-u', 'origin', branch], { cwd: workDir })

    log.step('Opening pull request…')
    return run('gh', ['pr', 'create', '--repo', UPSTREAM_REPO, '--head', `${username}:${branch}`, '--title', title, '--body', body], { cwd: workDir }).trim()
  } finally {
    rmSync(workDir, { recursive: true, force: true })
  }
}

async function interactiveContribute(args) {
  console.log('\n' + BANNER + '\n')
  p.intro(pc.bold('hooks') + pc.dim(`  Contribute local hook changes upstream · v${VERSION}`))

  const dirs = resolveScopeRoot(args.scope, { cwd: process.cwd(), home: homedir() })
  const candidates = findContributionCandidates(dirs, args.hooks)
  if (candidates.length === 0) {
    p.cancel(`No HookStack hooks found in ${dirs.hooksDir} — run install first.`)
    process.exit(1)
  }

  const spin = p.spinner()
  spin.start(`Comparing ${plural(candidates.length, 'hook')} against the catalogue…`)
  let changedHooks
  try {
    changedHooks = await loadChangedHooks(candidates, args.scope, dirs.root)
  } catch (e) {
    spin.stop(pc.red(`Fetch failed: ${e.message}`), 1)
    process.exit(1)
  }
  spin.stop(changedHooks.length > 0 ? `${plural(changedHooks.length, 'hook')} locally modified` : 'No local modifications found')

  if (changedHooks.length === 0) {
    p.outro(pc.dim('Nothing to contribute — your hooks match the published catalogue.'))
    return
  }

  const selected = await p.multiselect({
    message: 'Which modified hooks do you want to contribute?',
    options: changedHooks.map(h => ({ value: h.slug, label: h.slug })),
    initialValues: changedHooks.map(h => h.slug),
  })
  if (p.isCancel(selected) || selected.length === 0) return onCancel()

  const confirmed = await p.confirm({
    message: `Fork ${pc.cyan(UPSTREAM_REPO)} and open a PR for ${plural(selected.length, 'hook')}?`,
  })
  if (p.isCancel(confirmed) || !confirmed) return onCancel()

  const spin2 = p.spinner()
  spin2.start('Preparing contribution…')
  let prUrl
  try {
    prUrl = pushContribution(selected, dirs, { step: m => spin2.message(m) })
  } catch (e) {
    spin2.stop(pc.red(`Contribution failed: ${e.message}`), 1)
    process.exit(1)
  }
  if (!prUrl) {
    spin2.stop(pc.yellow('Nothing to push — your fork already has this exact content.'))
    return
  }
  spin2.stop('Pull request opened')
  p.outro(pc.green('Done!') + pc.dim(`  ${prUrl}`))
}

async function directContribute(args) {
  const dirs = resolveScopeRoot(args.scope, { cwd: process.cwd(), home: homedir() })
  const candidates = findContributionCandidates(dirs, args.hooks)
  if (candidates.length === 0) {
    console.error(`\n✗ No HookStack hooks found in ${dirs.hooksDir} — run install first.`)
    process.exit(1)
  }

  console.log(`\nComparing ${plural(candidates.length, 'hook')} against the catalogue…`)
  let changedHooks
  try {
    changedHooks = await loadChangedHooks(candidates, args.scope, dirs.root)
  } catch (e) {
    console.error(`\n✗ Failed: ${e.message}`)
    process.exit(1)
  }
  if (changedHooks.length === 0) {
    console.log('✓ Nothing to contribute — your hooks match the published catalogue.\n')
    return
  }

  const slugs = changedHooks.map(h => h.slug)
  console.log(`  Found ${plural(slugs.length, 'modified hook')}: ${slugs.join(', ')}`)
  let prUrl
  try {
    prUrl = pushContribution(slugs, dirs, { step: m => console.log(`  ${m}`) })
  } catch (e) {
    console.error(`\n✗ Contribution failed: ${e.message}`)
    process.exit(1)
  }
  if (!prUrl) {
    console.log('\n✓ Nothing to push — your fork already has this exact content.\n')
    return
  }
  console.log(`\n✅ Pull request opened: ${prUrl}\n`)
}

const HELP = `
  hookstack — Claude Code hook installer

  Usage:
    npx hookstack-cli@latest install              # install the default HookStack
    npx hookstack-cli@latest install --hooks=<slug1>,<slug2>,...  # custom selection
    npx hookstack-cli@latest update                # refresh already-installed hooks
    npx hookstack-cli@latest contribute             # PR your local hook edits upstream

  Options:
    --hooks <slugs>   Comma-separated list of hook slugs (omit for default set,
                      or to limit "contribute" to specific hooks)
    --global, -g      Target ~/.claude instead of ./.claude
    --copilot         Target ./.claude with paths adapted for GitHub Copilot
    --codex-project   Target ./.codex/hooks.json (OpenAI Codex, this repo)
    --codex-profile   Target ~/.codex/hooks.json (OpenAI Codex, all projects)
    --scope <s>       "project" (default), "global", "copilot",
                      "codex-project", or "codex-profile"
    --with-tests      Also install vitest unit tests into tests/hooks/ (install, project scope only)
    --yes, -y         Skip prompts (non-interactive)
    --version, -v     Show version
    --help, -h        Show this help

  "update" re-fetches every already-installed hook (detected via its
  @hookstack fingerprint) from the live registry and refreshes the local
  .mjs. settings.json is only touched if a hook's config actually changed.
  Use the same scope flag you installed with (--global, --codex-project…).

  "contribute" finds installed hooks whose local .mjs diverges from the live
  registry, forks ${UPSTREAM_REPO} for you, and opens a PR with those
  changes. Requires the GitHub CLI (gh), authenticated (\`gh auth login\`).

  Browse hooks at https://hookstack.vercel.app
`

async function main() {
  const args = parseArgs(process.argv)

  if (args.version) { console.log(VERSION); return }
  if (args.help) { console.log(HELP); return }

  const command = args.command ?? 'install'
  if (command !== 'install' && command !== 'update' && command !== 'contribute') {
    console.error(`✗ Unknown command: ${command}`)
    console.error('  Run --help for usage.')
    process.exit(1)
  }

  const interactive = Boolean(process.stdout.isTTY) && !args.yes

  if (command === 'update') {
    if (interactive) await interactiveUpdate(args)
    else await directUpdate(args)
    return
  }

  if (command === 'contribute') {
    if (interactive) await interactiveContribute(args)
    else await directContribute(args)
    return
  }

  if (interactive) await interactiveInstall(args.hooks, args)
  else await directInstall(args.hooks, args)
}

/* v8 ignore next 4 */
const _argv1 = (() => { try { return realpathSync(process.argv[1]) } catch { return process.argv[1] } })()
if (_argv1 === fileURLToPath(import.meta.url)) {
  main().catch(err => { console.error(pc.red(`\n✗ ${err.message || err}`)); process.exit(1) })
}
